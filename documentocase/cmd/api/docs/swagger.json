{
    "schemes": [
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Documento Service",
        "title": "Documento Service API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost",
    "basePath": "/api/v1/documento",
    "paths": {
        "/documento/add": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Documento"
                ],
                "summary": "Criar documento",
                "parameters": [
                    {
                        "type": "file",
                        "description": "Arquivos para upload (múltiplos)",
                        "name": "arquivos",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "202": {
                        "description": "accepted",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "invalid request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Endpoint de healthcheck",
                "tags": [
                    "health"
                ],
                "summary": "Retorna status da API",
                "responses": {
                    "200": {
                        "description": "ok",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}