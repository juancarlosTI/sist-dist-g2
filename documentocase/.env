# ========================
# POSTGRES (container)
# ========================
POSTGRES_USER=documento_bc
POSTGRES_PASSWORD=documento_pass
POSTGRES_DB=documentocase

# ========================
# APP (Go)
# ========================
DB_HOST=documento-postgres
DB_PORT=5432
DB_USER=documento_bc
DB_PASSWORD=documento_pass
DB_NAME=documentocase

# ========================
# OUTROS
# ========================
HTTP_PORT=10051
RABBIT_URL=amqp://guest:guest@rabbitmq:5672/

# ========================
# Min.IO S3
# ========================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123456
MINIO_BUCKET=documentos
MINIO_SSL=false